{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "Node16",
    "lib": ["ES2022"],
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "skipLibCheck": true,
    "declaration": true,
    "sourceMap": true
  },
  "include": ["src/core/**/*", "src/extension/**/*", "src/lsp/**/*", "src/webview/template.ts"],
  "exclude": ["node_modules", "dist", "tests", "src/webview/main.ts"]
}
